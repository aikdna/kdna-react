{
  "name": "@aikdna/kdna-react",
  "version": "0.2.0",
  "description": "React components and hooks for building KDNA-integrated web applications — file dropzone, load-plan gate, password unlock, license activation, and asset inspector.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "types": "./src/index.d.ts",
  "files": [
    "src/",
    "docs/",
    "LICENSE",
    "NOTICE",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "ci": "npm test && npm run typecheck && npm run lint && npm run build && npm pack --dry-run --json",
    "test": "node --test tests/react.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint.js",
    "build": "node scripts/build.js",
    "prepublishOnly": "npm run ci"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna-react.git"
  },
  "bugs": {
    "url": "https://github.com/aikdna/kdna-react/issues"
  },
  "homepage": "https://github.com/aikdna/kdna-react",
  "keywords": [
    "kdna",
    "kdna-react",
    "react",
    "components",
    "hooks",
    "judgment-asset"
  ]
}
