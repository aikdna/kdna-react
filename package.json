    "build": "node scripts/build.js"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18",
    "@aikdna/kdna-web-client": ">=0.1",
    "@aikdna/kdna-web-server": ">=0.1"
  },
  "peerDependenciesMeta": {
    "@aikdna/kdna-web-server": {
      "optional": true,
      "description": "Required if you use the default endpoint wiring. Omit only if you provide custom endpoint props."
    }
  },
  "dependencies": {},
