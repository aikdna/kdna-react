{
  "name": "@aikdna/kdna-react",
  "version": "0.2.1",
  "description": "React components and hooks for building KDNA-integrated web applications — file dropzone, load-plan gate, password unlock, license activation, and asset inspector.",
  "type": "module",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "default": "./src/index.js"
    }
  },
  "types": "./src/index.d.ts",
  "files": [
    "src/",
    "docs/",
    "LICENSE",
    "NOTICE",
    "README.md",
    "SECURITY.md"
  ],
  "scripts": {
    "ci": "npm run validators:check && npm test && npm run typecheck && npm run lint && npm run build && npm run size && npm run naming:check && npm run package:runtime-check && npm pack --dry-run --json",
    "test": "node --test tests/react.test.js",
    "typecheck": "tsc --noEmit",
    "lint": "node scripts/lint.js",
    "build": "node scripts/build.js",
    "size": "node scripts/size.js",
    "validators:generate": "node scripts/generate-runtime-validators.js --write",
    "validators:check": "node scripts/generate-runtime-validators.js --check",
    "naming:check": "node scripts/check-naming-integrity.js",
    "package:runtime-check": "node scripts/check-packed-runtime-boundary.js",
    "release:binding": "node scripts/check-release-binding.js",
    "prepublishOnly": "npm run ci"
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-dom": ">=18"
  },
  "devDependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.25.6",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.9.3"
  },
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aikdna/kdna-react.git"
  },
  "bugs": {
    "url": "https://github.com/aikdna/kdna-react/issues"
  },
  "homepage": "https://github.com/aikdna/kdna-react",
  "keywords": [
    "kdna",
    "kdna-react",
    "react",
    "components",
    "hooks",
    "judgment-asset"
  ]
}
